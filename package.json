{
  "name": "commitr",
  "displayName": "Commitr",
  "description": "Generate meaningful commit messages from your staged diff using a local AI. Private, offline, zero-config.",
  "version": "0.0.1",
  "publisher": "Shifali",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shifali/commitr"
  },
  "homepage": "https://github.com/shifali/commitr#readme",
  "bugs": {
    "url": "https://github.com/shifali/commitr/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "commit",
    "ai",
    "ollama",
    "conventional commits",
    "local ai",
    "offline"
  ],
  "activationEvents": [
    "onCommand:commitr.generateMessage"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commitr.generateMessage",
        "title": "Commitr: Generate Commit Message",
        "icon": "$(git-commit)"
      }
    ],
    "keybindings": [
      {
        "command": "commitr.generateMessage",
        "key": "ctrl+shift+alt+c",
        "mac": "cmd+shift+alt+c",
        "when": "scmProvider == git"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "commitr.generateMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "commandPalette": [
        {
          "command": "commitr.generateMessage"
        }
      ]
    },
    "configuration": {
      "title": "Commitr",
      "properties": {
        "commitr.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server base URL. Change this if you run Ollama on a custom port or remote host.",
          "order": 1
        },
        "commitr.model": {
          "type": "string",
          "default": "qwen2.5:3b",
          "markdownDescription": "Ollama model to use for generation. Must be pulled first — run `ollama pull qwen2.5:3b`. Any instruction-tuned model works.",
          "order": 2
        },
        "commitr.commitStyle": {
          "type": "string",
          "enum": [
            "conventional",
            "freeform"
          ],
          "enumDescriptions": [
            "Enforces type(scope): subject format (Conventional Commits spec).",
            "Lets the model write freely — no format enforced."
          ],
          "default": "conventional",
          "description": "Output format for generated commit messages.",
          "order": 3
        },
        "commitr.generateBody": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, generates a commit body for diffs spanning 3 or more files. Has no effect in freeform mode.",
          "order": 4
        },
        "commitr.scopeMappings": {
          "type": "object",
          "default": {},
          "markdownDescription": "Custom path prefix → scope overrides. Keys are path prefixes, values are scope names.\n\nExample:\n```json\n{\n  \"src/auth\": \"auth\",\n  \"src/payments\": \"payments\",\n  \"mobile/screens\": \"screens\"\n}\n```",
          "order": 5
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
